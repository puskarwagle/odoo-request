<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_cps">
        <field name="name">CPS Groups</field>
        <field name="description">CPS Groups access rights</field>
    </record>

    <record id="group_branch_users" model="res.groups">
        <field name="name">branchUsers</field>
        <field name="category_id" ref="module_category_cps"/>
    </record>

    <record id="group_central_users" model="res.groups">
        <field name="name">centralApprovers</field>
        <field name="category_id" ref="module_category_cps"/>
    </record>

    <record id="sequence_access_rule_branch_users" model="ir.rule">
        <field name="name">Sequence Access Rule for branchUsers</field>
        <field name="model_id" ref="model_ir_sequence"/>
        <field name="groups" eval="[(4, ref('service-approval.group_branch_users'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>